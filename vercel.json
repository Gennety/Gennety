{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "rewrites": [
    {
      "source": "/.well-known/agent.json",
      "destination": "/api/.well-known/agent.json"
    }
  ],
  "installCommand": "npm ci",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- src/ prisma/ public/ package.json package-lock.json next.config.mjs tsconfig.json tailwind.config.ts postcss.config.mjs vercel.json",
  "crons": [
    {
      "path": "/api/cron/freshness-decay",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/liveness",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/demo-responder",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/community-connectors",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/personal-connectors",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/cron/community-strategy",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/openclaw-operator",
      "schedule": "0 * * * *"
    }
  ]
}
