generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model Owner {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?   @map("password_hash")
  emailVerified   DateTime? @map("email_verified")
  image           String?
  networkingGoal  String?   @map("networking_goal")
  privacyConsent  Boolean   @default(false) @map("privacy_consent")
  researchConsent Boolean   @default(false) @map("research_consent") // Purpose B — separate GDPR basis
  excludedTopics  String[]  @default([]) @map("excluded_topics")
  agentPlatform   String?   @map("agent_platform") // "open_claw" | "nemo_claw" | "zero_claw" | "nano_claw"
  onboarded       Boolean   @default(false)

  // Notification preferences
  notifyAllEmails      Boolean @default(true) @map("notify_all_emails")
  notifyMatchProposals Boolean @default(true) @map("notify_match_proposals")
  notifyNewMessages    Boolean @default(true) @map("notify_new_messages")
  notifyFreshness      Boolean @default(true) @map("notify_freshness")

  createdAt       DateTime  @default(now()) @map("created_at")
  agent           Agent?
  accounts        Account[]
  consentLogs     ConsentLog[]
  blockedUsers    Block[]          @relation("Blocker")
  blockedBy       Block[]          @relation("Blocked")
  reports         Report[]
  matchReactions  MatchReaction[]
  matchComments   MatchComment[]

  @@map("owners")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Owner @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Agent {
  id           String   @id @default(cuid())
  agentId      String   @unique @map("agent_id") // "agent_arlan_001"
  ownerId      String   @unique @map("owner_id")
  owner        Owner    @relation(fields: [ownerId], references: [id])
  apiKey       String   @unique @map("api_key")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  displayName  String?  @map("display_name")  // public name for activity feed

  // Multi-agent support
  agentType         AgentType         @default(OPENCLAW) @map("agent_type")
  agentVersion      String?           @map("agent_version") // e.g. "openclaw-2.1", "claude-cowork-jan2026"
  integrationMethod IntegrationMethod @default(MCP) @map("integration_method")

  // Reputation fields
  reputationScore           Float  @default(40) @map("reputation_score")
  reputationAcceptanceRate  Float  @default(0)  @map("reputation_acceptance_rate")
  reputationNegotiationRate Float  @default(0)  @map("reputation_negotiation_rate")
  reputationCompletedMatches Int   @default(0)  @map("reputation_completed_matches")
  totalProposedMatches      Int    @default(0)  @map("total_proposed_matches")
  totalInitiatedNegotiations Int   @default(0)  @map("total_initiated_negotiations")
  totalAcceptedByOwner      Int    @default(0)  @map("total_accepted_by_owner")
  totalNegotiationsAgreed   Int    @default(0)  @map("total_negotiations_agreed")
  interactionCount          Int    @default(0)  @map("interaction_count")

  context  AgentContext?
  beacons  Beacon[]
  matchesAsA Match[] @relation("AgentA")
  matchesAsB Match[] @relation("AgentB")
  negotiationLogs NegotiationLog[]

  @@map("agents")
}

model AgentContext {
  id             String   @id @default(cuid())
  agentId        String   @unique @map("agent_id")
  agent          Agent    @relation(fields: [agentId], references: [id])

  // From USER.md — stable owner facts
  ownerName        String?  @map("owner_name")
  ownerLocation    String?  @map("owner_location")
  ownerProfession  String?  @map("owner_profession")
  ownerDomain      String?  @map("owner_domain")       // primary professional domain
  ownerExperience  String?  @map("owner_experience")    // years or level of experience
  ownerGoals       String?  @map("owner_goals")         // stated long-term goals

  // From AGENTS.md — agent role and specialization
  agentSpecialization String? @map("agent_specialization") // what the agent helps with
  agentDomains        String[] @default([]) @map("agent_domains") // domains the agent operates in
  agentConstraints    String?  @map("agent_constraints")   // focus areas or explicit limits

  // From SOUL.md — collaboration style signals
  collaborationStyle String? @map("collaboration_style") // how owner prefers to work with others
  communicationStyle String? @map("communication_style") // direct/async/structured etc.

  // From MEMORY.md — current active context
  currentWork    String   @map("current_work")    // what owner is building/working on right now
  expertise      String[]                          // areas of expertise
  lookingFor     String   @map("looking_for")      // what kind of person/collaboration owner needs
  notLookingFor  String?  @map("not_looking_for")  // what to filter out
  recentProblems String?  @map("recent_problems")  // what owner is stuck on
  recentWins     String?  @map("recent_wins")      // what owner just accomplished
  location       String?
  networkingGoal String   @map("networking_goal")   // partnership | collaboration | mentor | peer

  // Derived — combined embedding across all sources
  embedding      Unsupported("vector(1536)")?
  updatedAt      DateTime @updatedAt @map("updated_at")
  previousHash   String?  @map("previous_hash")    // hash of previous context for change detection

  // Freshness fields
  freshnessState          FreshnessState @default(ACTIVE) @map("freshness_state")
  lastSignificantUpdateAt DateTime       @default(now())  @map("last_significant_update_at")

  @@map("agent_contexts")
}

model Beacon {
  id           String    @id @default(cuid())
  agentId      String    @map("agent_id")
  agent        Agent     @relation(fields: [agentId], references: [id])
  contextQuery String    @map("context_query") // what this beacon is waiting for
  embedding    Unsupported("vector(1536)")?
  isActive     Boolean   @default(true) @map("is_active")
  preservable  Boolean   @default(true) // paused (true) vs deactivated (false)
  createdAt    DateTime  @default(now()) @map("created_at")
  triggeredAt  DateTime? @map("triggered_at")

  @@index([isActive])
  @@map("beacons")
}

model Match {
  id             String      @id @default(cuid())
  agentAId       String      @map("agent_a_id")
  agentBId       String      @map("agent_b_id")
  agentA         Agent       @relation("AgentA", fields: [agentAId], references: [id])
  agentB         Agent       @relation("AgentB", fields: [agentBId], references: [id])

  // Which agent actually initiated the negotiation. (agentA/B is normalized by
  // id order for the uniqueness constraint and doesn't reflect initiation.)
  initiatorAgentId String?   @map("initiator_agent_id")

  overlapSummary String      @map("overlap_summary")  // what agents decided in negotiation
  framingForA    String      @map("framing_for_a")     // how to present to owner A
  framingForB    String      @map("framing_for_b")     // how to present to owner B

  status         MatchStatus @default(NEGOTIATING)
  confirmedByA   Boolean     @default(false) @map("confirmed_by_a")
  confirmedByB   Boolean     @default(false) @map("confirmed_by_b")
  isPublic       Boolean     @default(true) @map("is_public")

  createdAt      DateTime    @default(now()) @map("created_at")
  proposedAt     DateTime?   @map("proposed_at")
  matchedAt      DateTime?   @map("matched_at")

  chat           Chat?
  negotiationLogs NegotiationLog[]
  reactions       MatchReaction[]
  comments        MatchComment[]

  @@unique([agentAId, agentBId])
  @@map("matches")
}

enum MatchStatus {
  NEGOTIATING
  PROPOSED
  MATCHED
  DORMANT
  DECLINED
}

enum FreshnessState {
  ACTIVE
  AGING
  STALE
  INACTIVE
}

enum AgentType {
  OPENCLAW          // OpenClaw and all derivatives (ZeroClaw, NemoClaw, SoulClaw, IronClaw)
}

enum IntegrationMethod {
  MCP               // Connected via MCP
}

model Chat {
  id        String     @id @default(cuid())
  matchId   String     @unique @map("match_id")
  match     Match      @relation(fields: [matchId], references: [id])
  status    ChatStatus @default(OPEN)
  createdAt DateTime   @default(now()) @map("created_at")

  // Read cursors — tracks when each owner last viewed this chat
  lastReadByA DateTime? @map("last_read_by_a")
  lastReadByB DateTime? @map("last_read_by_b")

  // Email notification throttle — tracks when each owner was last emailed about new messages
  lastNotifiedA DateTime? @map("last_notified_a")
  lastNotifiedB DateTime? @map("last_notified_b")

  messages  Message[]
  reports   Report[]

  @@map("chats")
}

enum ChatStatus {
  OPEN
  ARCHIVED
  BLOCKED
}

model Message {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  chat      Chat     @relation(fields: [chatId], references: [id])
  fromOwner String   @map("from_owner") // owner id or "agent_a" / "agent_b" for opening messages
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model NegotiationLog {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id])
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id])
  role      String   // "initiator" | "responder"
  type      String   // "reasoning" | "proposal" | "evaluation" | "agreement" | "decline"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("negotiation_logs")
}

model MatchReaction {
  id        String       @id @default(cuid())
  matchId   String       @map("match_id")
  match     Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String       @map("owner_id")
  owner     Owner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([matchId, ownerId])
  @@index([matchId])
  @@map("match_reactions")
}

model MatchComment {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String   @map("owner_id")
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("match_comments")
}

enum ReactionType {
  LIKE
  DISLIKE
}

model ConsentLog {
  id          String    @id @default(cuid())
  ownerId     String    @map("owner_id")
  owner       Owner     @relation(fields: [ownerId], references: [id])
  purpose     String    // "A" (networking) | "B" (research)
  consentedAt DateTime  @default(now()) @map("consented_at")
  withdrawnAt DateTime? @map("withdrawn_at")

  @@index([ownerId])
  @@map("consent_logs")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blocker   Owner    @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String   @map("blocked_id")
  blocked   Owner    @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Report {
  id         String   @id @default(cuid())
  chatId     String   @map("chat_id")
  chat       Chat     @relation(fields: [chatId], references: [id])
  reporterId String   @map("reporter_id")
  reporter   Owner    @relation(fields: [reporterId], references: [id])
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model EmailNotification {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  type        String   // MATCH_PROPOSAL | MATCH_CONFIRMED | NEW_MESSAGE | FRESHNESS_WARNING
  referenceId String   @map("reference_id") // matchId or chatId
  resendId    String?  @map("resend_id")
  sentAt      DateTime @default(now()) @map("sent_at")

  @@index([ownerId, type, referenceId])
  @@index([sentAt])
  @@map("email_notifications")
}
