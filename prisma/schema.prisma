generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model Owner {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?   @map("password_hash")
  emailVerified   DateTime? @map("email_verified")
  image           String?
  networkingGoal  String?   @map("networking_goal")
  countryCode     String?   @map("country_code")
  privacyConsent  Boolean   @default(false) @map("privacy_consent")
  researchConsent Boolean   @default(false) @map("research_consent") // Purpose B — separate GDPR basis
  excludedTopics  String[]  @default([]) @map("excluded_topics")
  agentPlatform   String?   @map("agent_platform") // "open_claw" | "nemo_claw" | "zero_claw" | "nano_claw"
  onboarded       Boolean   @default(false)

  // Demo network — simulated accounts driven by the server-side responder.
  // Filtered out of production analytics and reputation leaderboards.
  isDemo Boolean @default(false) @map("is_demo")

  createdAt                DateTime          @default(now()) @map("created_at")
  agent                    Agent?
  accounts                 Account[]
  consentLogs              ConsentLog[]
  blockedUsers             Block[]           @relation("Blocker")
  blockedBy                Block[]           @relation("Blocked")
  reports                  Report[]
  matchReactions           MatchReaction[]
  matchComments            MatchComment[]
  communitiesOwned         Community[]       @relation("CommunityOwner")
  communityMemberships     CommunityMember[]
  communityInvitesSent     CommunityInvite[] @relation("CommunityInviteInviter")
  communityInvitesReceived CommunityInvite[] @relation("CommunityInviteInvitee")

  @@index([isDemo])
  @@map("owners")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Owner @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Agent {
  id           String   @id @default(cuid())
  agentId      String   @unique @map("agent_id") // "agent_arlan_001"
  ownerId      String   @unique @map("owner_id")
  owner        Owner    @relation(fields: [ownerId], references: [id])
  apiKey       String   @unique @map("api_key")
  isActive     Boolean  @default(true) @map("is_active")
  searchPaused Boolean  @default(false) @map("search_paused")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  displayName String? @map("display_name") // public name for activity feed

  // Multi-agent support
  agentType         AgentType         @default(OPENCLAW) @map("agent_type")
  agentVersion      String?           @map("agent_version") // e.g. "openclaw-2.1", "claude-cowork-jan2026"
  integrationMethod IntegrationMethod @default(MCP) @map("integration_method")

  // Wake-up delivery. Outbound SSE is primary; webhook fields are legacy
  // fallback for agents that expose POST /hooks/wake.
  webhookUrl                   String?   @map("webhook_url")
  webhookToken                 String?   @map("webhook_token")
  wakeWebhookEnabled           Boolean   @default(false) @map("wake_webhook_enabled")
  wakeWebhookLastPingAt        DateTime? @map("wake_webhook_last_ping_at")
  wakeWebhookLastPingOk        Boolean?  @map("wake_webhook_last_ping_ok")
  wakeWebhookLastPingError     String?   @map("wake_webhook_last_ping_error")
  wakeStreamLastConnectedAt    DateTime? @map("wake_stream_last_connected_at")
  wakeStreamLastSeenAt         DateTime? @map("wake_stream_last_seen_at")
  wakeStreamLastDisconnectedAt DateTime? @map("wake_stream_last_disconnected_at")
  wakeStreamLastError          String?   @map("wake_stream_last_error")

  // Reputation fields
  reputationScore            Float @default(40) @map("reputation_score")
  reputationAcceptanceRate   Float @default(0) @map("reputation_acceptance_rate")
  reputationNegotiationRate  Float @default(0) @map("reputation_negotiation_rate")
  reputationCompletedMatches Int   @default(0) @map("reputation_completed_matches")
  totalProposedMatches       Int   @default(0) @map("total_proposed_matches")
  totalInitiatedNegotiations Int   @default(0) @map("total_initiated_negotiations")
  totalAcceptedByOwner       Int   @default(0) @map("total_accepted_by_owner")
  totalNegotiationsAgreed    Int   @default(0) @map("total_negotiations_agreed")
  interactionCount           Int   @default(0) @map("interaction_count")

  // Demo network fields — simulated agents driven by the server-side responder.
  // When isDemo=true, demoPersona contains LLM-ready traits used by
  // src/lib/demo/responder-brain.ts to generate in-character responses.
  isDemo         Boolean   @default(false) @map("is_demo")
  demoPersona    Json?     @map("demo_persona")
  lastDemoTickAt DateTime? @map("last_demo_tick_at")

  context         AgentContext?
  beacons         Beacon[]
  matchesAsA      Match[]          @relation("AgentA")
  matchesAsB      Match[]          @relation("AgentB")
  negotiationLogs NegotiationLog[]

  @@index([isDemo])
  @@index([isDemo, lastDemoTickAt])
  @@map("agents")
}

model AgentContext {
  id      String @id @default(cuid())
  agentId String @unique @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  // From USER.md — stable owner facts
  ownerName       String? @map("owner_name")
  ownerLocation   String? @map("owner_location")
  ownerProfession String? @map("owner_profession")
  ownerDomain     String? @map("owner_domain") // primary professional domain
  ownerExperience String? @map("owner_experience") // years or level of experience
  ownerGoals      String? @map("owner_goals") // stated long-term goals

  // From AGENTS.md — agent role and specialization
  agentSpecialization String?  @map("agent_specialization") // what the agent helps with
  agentDomains        String[] @default([]) @map("agent_domains") // domains the agent operates in
  agentConstraints    String?  @map("agent_constraints") // focus areas or explicit limits

  // From SOUL.md — collaboration style signals
  collaborationStyle String? @map("collaboration_style") // how owner prefers to work with others
  communicationStyle String? @map("communication_style") // direct/async/structured etc.

  // From MEMORY.md — current active context
  currentWork    String   @map("current_work") // what owner is building/working on right now
  expertise      String[] // areas of expertise
  lookingFor     String   @map("looking_for") // what kind of person/collaboration owner needs
  notLookingFor  String?  @map("not_looking_for") // what to filter out
  recentProblems String?  @map("recent_problems") // what owner is stuck on
  recentWins     String?  @map("recent_wins") // what owner just accomplished
  location       String?
  networkingGoal String   @map("networking_goal") // partnership | collaboration | mentor | peer

  // Derived — combined embedding across all sources
  embedding    Unsupported("vector(1536)")?
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  previousHash String?                      @map("previous_hash") // hash of previous context for change detection

  // Freshness fields
  freshnessState          FreshnessState @default(ACTIVE) @map("freshness_state")
  lastSignificantUpdateAt DateTime       @default(now()) @map("last_significant_update_at")

  @@map("agent_contexts")
}

model Beacon {
  id                   String                       @id @default(cuid())
  agentId              String                       @map("agent_id")
  agent                Agent                        @relation(fields: [agentId], references: [id])
  contextQuery         String                       @map("context_query") // what this beacon is waiting for
  networkingGoalFilter String?                      @map("networking_goal_filter")
  embedding            Unsupported("vector(1536)")?
  isActive             Boolean                      @default(true) @map("is_active")
  preservable          Boolean                      @default(true) // paused (true) vs deactivated (false)
  createdAt            DateTime                     @default(now()) @map("created_at")
  triggeredAt          DateTime?                    @map("triggered_at")

  @@index([isActive])
  @@map("beacons")
}

model Match {
  id       String @id @default(cuid())
  agentAId String @map("agent_a_id")
  agentBId String @map("agent_b_id")
  agentA   Agent  @relation("AgentA", fields: [agentAId], references: [id])
  agentB   Agent  @relation("AgentB", fields: [agentBId], references: [id])

  // Which agent actually initiated the negotiation. (agentA/B is normalized by
  // id order for the uniqueness constraint and doesn't reflect initiation.)
  initiatorAgentId String? @map("initiator_agent_id")

  overlapSummary String @map("overlap_summary") // what agents decided in negotiation
  framingForA    String @map("framing_for_a") // how to present to owner A
  framingForB    String @map("framing_for_b") // how to present to owner B

  // V2 analytics fields — used for exact dashboard metrics.
  matchSimilarity  Float?               @map("match_similarity")
  discoverySource  MatchDiscoverySource @default(UNKNOWN) @map("discovery_source")
  sourceBeaconId   String?              @map("source_beacon_id")
  agentAAcceptedAt DateTime?            @map("agent_a_accepted_at")
  agentBAcceptedAt DateTime?            @map("agent_b_accepted_at")

  status       MatchStatus @default(NEGOTIATING)
  confirmedByA Boolean     @default(false) @map("confirmed_by_a")
  confirmedByB Boolean     @default(false) @map("confirmed_by_b")
  isPublic     Boolean     @default(true) @map("is_public")

  createdAt  DateTime  @default(now()) @map("created_at")
  proposedAt DateTime? @map("proposed_at")
  matchedAt  DateTime? @map("matched_at")

  chat            Chat?
  negotiationLogs NegotiationLog[]
  reactions       MatchReaction[]
  comments        MatchComment[]

  @@unique([agentAId, agentBId])
  @@map("matches")
}

enum MatchStatus {
  NEGOTIATING
  PROPOSED
  MATCHED
  DORMANT
  DECLINED
}

enum MatchDiscoverySource {
  UNKNOWN
  SEARCH
  BEACON
}

enum FreshnessState {
  ACTIVE
  AGING
  STALE
  INACTIVE
}

enum AgentType {
  OPENCLAW // OpenClaw and all derivatives (ZeroClaw, NemoClaw, SoulClaw, IronClaw)
}

enum IntegrationMethod {
  MCP // Connected via MCP
}

model Chat {
  id        String     @id @default(cuid())
  matchId   String     @unique @map("match_id")
  match     Match      @relation(fields: [matchId], references: [id])
  status    ChatStatus @default(OPEN)
  createdAt DateTime   @default(now()) @map("created_at")

  // Read cursors — tracks when each owner last viewed this chat
  lastReadByA DateTime? @map("last_read_by_a")
  lastReadByB DateTime? @map("last_read_by_b")

  // Email notification throttle — tracks when each owner was last emailed about new messages
  lastNotifiedA DateTime? @map("last_notified_a")
  lastNotifiedB DateTime? @map("last_notified_b")

  messages       Message[]
  reports        Report[]
  adviceSessions AdviceSession[]

  @@map("chats")
}

enum ChatStatus {
  OPEN
  ARCHIVED
  BLOCKED
}

enum AdviceSessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
  FAILED
  CANCELLED
}

enum MessageKind {
  HUMAN
  AGENT_INTRO
  MODEL_ADVICE_REQUEST
  MODEL_ADVICE_STATUS
  MODEL_ADVICE_AGENT
  MODEL_ADVICE_RESULT
}

model Message {
  id              String         @id @default(cuid())
  chatId          String         @map("chat_id")
  chat            Chat           @relation(fields: [chatId], references: [id])
  fromOwner       String         @map("from_owner") // owner id or "agent_a" / "agent_b" for opening messages
  kind            MessageKind    @default(HUMAN)
  adviceSessionId String?        @map("advice_session_id")
  adviceSession   AdviceSession? @relation(fields: [adviceSessionId], references: [id], onDelete: SetNull)
  content         String
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@index([adviceSessionId])
  @@map("messages")
}

model AdviceSession {
  id                 String              @id @default(cuid())
  chatId             String              @map("chat_id")
  chat               Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  requestedByOwnerId String              @map("requested_by_owner_id")
  responderOwnerId   String?             @map("responder_owner_id")
  promptKey          String?             @map("prompt_key")
  promptTitle        String              @map("prompt_title")
  promptText         String              @map("prompt_text")
  status             AdviceSessionStatus @default(PENDING)
  respondedAt        DateTime?           @map("responded_at")
  startedAt          DateTime?           @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  summary            String?             @map("summary")
  recommendation     String?             @map("recommendation")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  messages Message[]

  @@index([chatId, status])
  @@index([requestedByOwnerId, status])
  @@map("advice_sessions")
}

model NegotiationLog {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id])
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id])
  role      String // "initiator" | "responder"
  type      String // "reasoning" | "proposal" | "evaluation" | "agreement" | "decline"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("negotiation_logs")
}

model MatchReaction {
  id        String       @id @default(cuid())
  matchId   String       @map("match_id")
  match     Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String       @map("owner_id")
  owner     Owner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([matchId, ownerId])
  @@index([matchId])
  @@map("match_reactions")
}

model MatchComment {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String   @map("owner_id")
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("match_comments")
}

enum ReactionType {
  LIKE
  DISLIKE
}

model ConsentLog {
  id          String    @id @default(cuid())
  ownerId     String    @map("owner_id")
  owner       Owner     @relation(fields: [ownerId], references: [id])
  purpose     String // "A" (networking) | "B" (research)
  consentedAt DateTime  @default(now()) @map("consented_at")
  withdrawnAt DateTime? @map("withdrawn_at")

  @@index([ownerId])
  @@map("consent_logs")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blocker   Owner    @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String   @map("blocked_id")
  blocked   Owner    @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Community {
  id                         String                     @id @default(cuid())
  ownerId                    String                     @map("owner_id")
  owner                      Owner                      @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  slug                       String                     @unique
  name                       String
  description                String?                    @db.Text
  visibility                 CommunityVisibility        @default(PRIVATE)
  profileVisibility          CommunityProfileVisibility @default(VISIBLE) @map("profile_visibility")
  category                   CommunityCategory?
  specialization             CommunitySpecialization?
  status                     CommunityStatus            @default(ACTIVE)
  ssotEnabled                Boolean                    @default(false) @map("ssot_enabled")
  knowledgeSummary           String?                    @map("knowledge_summary") @db.Text
  strategyEnabled            Boolean                    @default(false) @map("strategy_enabled")
  strategyIntervalHours      Int                        @default(72) @map("strategy_interval_hours")
  lastStrategySessionAt      DateTime?                  @map("last_strategy_session_at")
  nextStrategySessionAt      DateTime?                  @map("next_strategy_session_at")
  strategyTokenLimit         Int                        @default(80000) @map("strategy_token_limit")
  monthlyTokenLimit          Int?                       @map("monthly_token_limit")
  judgeIterationLimit        Int                        @default(3) @map("judge_iteration_limit")
  strategyLockUntil          DateTime?                  @map("strategy_lock_until")
  roleChangesRequireApproval Boolean                    @default(true) @map("role_changes_require_approval")
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @updatedAt @map("updated_at")

  members            CommunityMember[]
  invites            CommunityInvite[]
  inviteHandshakes   CommunityInviteHandshake[]
  channels           CommunityChannel[]
  knowledgeSources   CommunityKnowledgeSource[]
  knowledgeDocuments CommunityKnowledgeDocument[]
  knowledgeChunks    CommunityKnowledgeChunk[]
  strategySessions   CommunityStrategySession[]
  strategyTurns      CommunityStrategyTurn[]
  actionProposals    CommunityActionProposal[]

  @@index([ownerId])
  @@index([visibility, status, category])
  @@index([strategyEnabled, nextStrategySessionAt])
  @@map("communities")
}

model CommunityMember {
  id                        String                @id @default(cuid())
  communityId               String                @map("community_id")
  community                 Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  ownerId                   String                @map("owner_id")
  owner                     Owner                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  role                      CommunityMemberRole   @default(MEMBER)
  status                    CommunityMemberStatus @default(ACTIVE)
  showOnProfile             Boolean               @default(true) @map("show_on_profile")
  hubTitle                  String?               @map("hub_title")
  hubSpecialization         String?               @map("hub_specialization")
  skillTags                 String[]              @default([]) @map("skill_tags")
  capacityHoursPerWeek      Int?                  @map("capacity_hours_per_week")
  currentLoadScore          Float?                @map("current_load_score")
  agentParticipationEnabled Boolean               @default(true) @map("agent_participation_enabled")
  shareContextWithCommunity Boolean               @default(false) @map("share_context_with_community")
  shareWorkloadSignals      Boolean               @default(false) @map("share_workload_signals")
  lastRoleMappedAt          DateTime?             @map("last_role_mapped_at")
  roleMappingConfidence     Float?                @map("role_mapping_confidence")
  joinedAt                  DateTime              @default(now()) @map("joined_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  @@unique([communityId, ownerId])
  @@index([ownerId, status, showOnProfile])
  @@index([communityId, status])
  @@map("community_members")
}

model CommunityInvite {
  id             String                @id @default(cuid())
  communityId    String                @map("community_id")
  community      Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviterOwnerId String                @map("inviter_owner_id")
  inviterOwner   Owner                 @relation("CommunityInviteInviter", fields: [inviterOwnerId], references: [id], onDelete: Cascade)
  inviteeOwnerId String?               @map("invitee_owner_id")
  inviteeOwner   Owner?                @relation("CommunityInviteInvitee", fields: [inviteeOwnerId], references: [id], onDelete: Cascade)
  inviteeEmail   String?               @map("invitee_email")
  tokenHash      String                @unique @map("token_hash")
  status         CommunityInviteStatus @default(PENDING)
  expiresAt      DateTime              @map("expires_at")
  acceptedAt     DateTime?             @map("accepted_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  handshake CommunityInviteHandshake?

  @@index([communityId, status])
  @@index([inviteeOwnerId, status])
  @@index([inviteeEmail, status])
  @@index([expiresAt])
  @@map("community_invites")
}

model CommunityInviteHandshake {
  id                        String                   @id @default(cuid())
  inviteId                  String                   @unique @map("invite_id")
  invite                    CommunityInvite          @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  communityId               String                   @map("community_id")
  community                 Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviteeOwnerId            String                   @map("invitee_owner_id")
  inviteeAgentId            String?                  @map("invitee_agent_id")
  ownerAgentId              String?                  @map("owner_agent_id")
  status                    CommunityHandshakeStatus @default(PENDING)
  recommendedRole           CommunityMemberRole?     @map("recommended_role")
  recommendedTitle          String?                  @map("recommended_title")
  recommendedSpecialization String?                  @map("recommended_specialization")
  recommendedSkillTags      String[]                 @default([]) @map("recommended_skill_tags")
  confidence                Float?
  candidateSummary          String?                  @map("candidate_summary") @db.Text
  ownerAgentSummary         String?                  @map("owner_agent_summary") @db.Text
  judgeSummary              String?                  @map("judge_summary") @db.Text
  failureReason             String?                  @map("failure_reason") @db.Text
  startedAt                 DateTime?                @map("started_at")
  completedAt               DateTime?                @map("completed_at")
  expiresAt                 DateTime                 @map("expires_at")
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")

  @@index([communityId, status])
  @@index([inviteeOwnerId, status])
  @@index([expiresAt])
  @@map("community_invite_handshakes")
}

model CommunityChannel {
  id              String    @id @default(cuid())
  communityId     String    @map("community_id")
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  slug            String
  name            String
  description     String?   @db.Text
  knowledgeFilter Json?     @map("knowledge_filter")
  semanticQuery   String?   @map("semantic_query") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([communityId, slug])
  @@index([communityId])
  @@map("community_channels")
}

model CommunityKnowledgeSource {
  id                   String                         @id @default(cuid())
  communityId          String                         @map("community_id")
  community            Community                      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  type                 CommunityKnowledgeSourceType
  name                 String
  config               Json?
  status               CommunityKnowledgeSourceStatus @default(ACTIVE)
  syncCursor           String?                        @map("sync_cursor")
  lastSyncedAt         DateTime?                      @map("last_synced_at")
  lastSuccessfulSyncAt DateTime?                      @map("last_successful_sync_at")
  lastError            String?                        @map("last_error") @db.Text
  createdByOwnerId     String?                        @map("created_by_owner_id")
  createdAt            DateTime                       @default(now()) @map("created_at")
  updatedAt            DateTime                       @updatedAt @map("updated_at")

  documents CommunityKnowledgeDocument[]

  @@index([communityId, type, status])
  @@map("community_knowledge_sources")
}

model CommunityKnowledgeDocument {
  id               String                           @id @default(cuid())
  communityId      String                           @map("community_id")
  community        Community                        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sourceId         String                           @map("source_id")
  source           CommunityKnowledgeSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId       String?                          @map("external_id")
  title            String
  url              String?
  sourceHash       String                           @map("source_hash")
  distilledHash    String?                          @map("distilled_hash")
  distilledContent String?                          @map("distilled_content") @db.Text
  summary          String?                          @db.Text
  tags             String[]                         @default([])
  privacyLevel     CommunityKnowledgePrivacy        @default(COMMUNITY) @map("privacy_level")
  status           CommunityKnowledgeDocumentStatus @default(ACTIVE)
  staleAfter       DateTime?                        @map("stale_after")
  supersededAt     DateTime?                        @map("superseded_at")
  metadata         Json?
  createdAt        DateTime                         @default(now()) @map("created_at")
  updatedAt        DateTime                         @updatedAt @map("updated_at")

  chunks CommunityKnowledgeChunk[]

  @@unique([sourceId, externalId])
  @@index([communityId, status, privacyLevel])
  @@index([communityId, sourceHash])
  @@map("community_knowledge_documents")
}

model CommunityKnowledgeChunk {
  id           String                       @id @default(cuid())
  communityId  String                       @map("community_id")
  community    Community                    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  documentId   String                       @map("document_id")
  document     CommunityKnowledgeDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content      String                       @db.Text
  embedding    Unsupported("vector(1536)")?
  tokenCount   Int                          @default(0) @map("token_count")
  tags         String[]                     @default([])
  privacyLevel CommunityKnowledgePrivacy    @default(COMMUNITY) @map("privacy_level")
  metadata     Json?
  createdAt    DateTime                     @default(now()) @map("created_at")

  @@index([communityId, privacyLevel])
  @@index([documentId])
  @@map("community_knowledge_chunks")
}

model CommunityStrategySession {
  id                    String                         @id @default(cuid())
  communityId           String                         @map("community_id")
  community             Community                      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  status                CommunityStrategySessionStatus @default(SCHEDULED)
  scheduledFor          DateTime                       @map("scheduled_for")
  startedAt             DateTime?                      @map("started_at")
  completedAt           DateTime?                      @map("completed_at")
  maxRounds             Int                            @default(2) @map("max_rounds")
  judgeIterationLimit   Int                            @default(3) @map("judge_iteration_limit")
  tokenLimit            Int                            @map("token_limit")
  tokensUsed            Int                            @default(0) @map("tokens_used")
  costUsd               Float                          @default(0) @map("cost_usd")
  summary               String?                        @db.Text
  judgeVerdict          Json?                          @map("judge_verdict")
  partnershipCandidates Json?                          @map("partnership_candidates")
  failureReason         String?                        @map("failure_reason") @db.Text
  createdAt             DateTime                       @default(now()) @map("created_at")
  updatedAt             DateTime                       @updatedAt @map("updated_at")

  turns           CommunityStrategyTurn[]
  actionProposals CommunityActionProposal[]

  @@index([communityId, status, scheduledFor])
  @@map("community_strategy_sessions")
}

model CommunityStrategyTurn {
  id           String                    @id @default(cuid())
  sessionId    String                    @map("session_id")
  session      CommunityStrategySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  communityId  String                    @map("community_id")
  community    Community                 @relation(fields: [communityId], references: [id], onDelete: Cascade)
  agentId      String?                   @map("agent_id")
  memberId     String?                   @map("member_id")
  role         CommunityStrategyTurnRole
  round        Int
  inputHash    String?                   @map("input_hash")
  output       Json
  tokensInput  Int                       @default(0) @map("tokens_input")
  tokensOutput Int                       @default(0) @map("tokens_output")
  createdAt    DateTime                  @default(now()) @map("created_at")

  @@index([sessionId, round, role])
  @@map("community_strategy_turns")
}

model CommunityActionProposal {
  id               String                        @id @default(cuid())
  communityId      String                        @map("community_id")
  community        Community                     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sessionId        String?                       @map("session_id")
  session          CommunityStrategySession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type             CommunityActionProposalType
  status           CommunityActionProposalStatus @default(PENDING)
  title            String
  summary          String                        @db.Text
  evidenceIds      String[]                      @default([]) @map("evidence_ids")
  payload          Json
  judgeConfidence  Float?                        @map("judge_confidence")
  requiresRole     CommunityMemberRole           @default(ADMIN) @map("requires_role")
  decidedByOwnerId String?                       @map("decided_by_owner_id")
  decidedAt        DateTime?                     @map("decided_at")
  createdAt        DateTime                      @default(now()) @map("created_at")

  @@index([communityId, status, type])
  @@map("community_action_proposals")
}

