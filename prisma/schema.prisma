generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model Owner {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?   @map("password_hash")
  emailVerified   DateTime? @map("email_verified")
  image           String?
  networkingGoal  String?   @map("networking_goal")
  countryCode     String?   @map("country_code")
  privacyConsent  Boolean   @default(false) @map("privacy_consent")
  researchConsent Boolean   @default(false) @map("research_consent") // Purpose B — separate GDPR basis
  excludedTopics  String[]  @default([]) @map("excluded_topics")
  agentPlatform   String?   @map("agent_platform") // "open_claw" | "nemo_claw" | "zero_claw" | "nano_claw"
  onboarded       Boolean   @default(false)

  // Demo network — simulated accounts driven by the server-side responder.
  // Filtered out of production analytics and reputation leaderboards.
  isDemo Boolean @default(false) @map("is_demo")

  createdAt      DateTime        @default(now()) @map("created_at")
  agent          Agent?
  accounts       Account[]
  consentLogs    ConsentLog[]
  blockedUsers   Block[]         @relation("Blocker")
  blockedBy      Block[]         @relation("Blocked")
  reports        Report[]
  matchReactions MatchReaction[]
  matchComments  MatchComment[]

  @@index([isDemo])
  @@map("owners")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Owner @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Agent {
  id           String   @id @default(cuid())
  agentId      String   @unique @map("agent_id") // "agent_arlan_001"
  ownerId      String   @unique @map("owner_id")
  owner        Owner    @relation(fields: [ownerId], references: [id])
  apiKey       String   @unique @map("api_key")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  displayName String? @map("display_name") // public name for activity feed

  // Multi-agent support
  agentType         AgentType         @default(OPENCLAW) @map("agent_type")
  agentVersion      String?           @map("agent_version") // e.g. "openclaw-2.1", "claude-cowork-jan2026"
  integrationMethod IntegrationMethod @default(MCP) @map("integration_method")

  // Wake-up push — when set, Gennety POSTs to webhookUrl with webhookToken
  // on hot events so the agent can call check_in immediately instead of
  // waiting for the next heartbeat.
  webhookUrl             String?   @map("webhook_url")
  webhookToken           String?   @map("webhook_token")
  wakeWebhookEnabled     Boolean   @default(false) @map("wake_webhook_enabled")
  wakeWebhookLastPingAt  DateTime? @map("wake_webhook_last_ping_at")
  wakeWebhookLastPingOk  Boolean?  @map("wake_webhook_last_ping_ok")
  wakeWebhookLastPingError String? @map("wake_webhook_last_ping_error")

  // Reputation fields
  reputationScore            Float @default(40) @map("reputation_score")
  reputationAcceptanceRate   Float @default(0) @map("reputation_acceptance_rate")
  reputationNegotiationRate  Float @default(0) @map("reputation_negotiation_rate")
  reputationCompletedMatches Int   @default(0) @map("reputation_completed_matches")
  totalProposedMatches       Int   @default(0) @map("total_proposed_matches")
  totalInitiatedNegotiations Int   @default(0) @map("total_initiated_negotiations")
  totalAcceptedByOwner       Int   @default(0) @map("total_accepted_by_owner")
  totalNegotiationsAgreed    Int   @default(0) @map("total_negotiations_agreed")
  interactionCount           Int   @default(0) @map("interaction_count")

  // Demo network fields — simulated agents driven by the server-side responder.
  // When isDemo=true, demoPersona contains LLM-ready traits used by
  // src/lib/demo/responder-brain.ts to generate in-character responses.
  isDemo         Boolean   @default(false) @map("is_demo")
  demoPersona    Json?     @map("demo_persona")
  lastDemoTickAt DateTime? @map("last_demo_tick_at")

  context         AgentContext?
  beacons         Beacon[]
  matchesAsA      Match[]          @relation("AgentA")
  matchesAsB      Match[]          @relation("AgentB")
  negotiationLogs NegotiationLog[]

  @@index([isDemo])
  @@index([isDemo, lastDemoTickAt])
  @@map("agents")
}

model AgentContext {
  id      String @id @default(cuid())
  agentId String @unique @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  // From USER.md — stable owner facts
  ownerName       String? @map("owner_name")
  ownerLocation   String? @map("owner_location")
  ownerProfession String? @map("owner_profession")
  ownerDomain     String? @map("owner_domain") // primary professional domain
  ownerExperience String? @map("owner_experience") // years or level of experience
  ownerGoals      String? @map("owner_goals") // stated long-term goals

  // From AGENTS.md — agent role and specialization
  agentSpecialization String?  @map("agent_specialization") // what the agent helps with
  agentDomains        String[] @default([]) @map("agent_domains") // domains the agent operates in
  agentConstraints    String?  @map("agent_constraints") // focus areas or explicit limits

  // From SOUL.md — collaboration style signals
  collaborationStyle String? @map("collaboration_style") // how owner prefers to work with others
  communicationStyle String? @map("communication_style") // direct/async/structured etc.

  // From MEMORY.md — current active context
  currentWork    String   @map("current_work") // what owner is building/working on right now
  expertise      String[] // areas of expertise
  lookingFor     String   @map("looking_for") // what kind of person/collaboration owner needs
  notLookingFor  String?  @map("not_looking_for") // what to filter out
  recentProblems String?  @map("recent_problems") // what owner is stuck on
  recentWins     String?  @map("recent_wins") // what owner just accomplished
  location       String?
  networkingGoal String   @map("networking_goal") // partnership | collaboration | mentor | peer

  // Derived — combined embedding across all sources
  embedding    Unsupported("vector(1536)")?
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  previousHash String?                      @map("previous_hash") // hash of previous context for change detection

  // Freshness fields
  freshnessState          FreshnessState @default(ACTIVE) @map("freshness_state")
  lastSignificantUpdateAt DateTime       @default(now()) @map("last_significant_update_at")

  @@map("agent_contexts")
}

model Beacon {
  id           String                       @id @default(cuid())
  agentId      String                       @map("agent_id")
  agent        Agent                        @relation(fields: [agentId], references: [id])
  contextQuery String                       @map("context_query") // what this beacon is waiting for
  networkingGoalFilter String?              @map("networking_goal_filter")
  embedding    Unsupported("vector(1536)")?
  isActive     Boolean                      @default(true) @map("is_active")
  preservable  Boolean                      @default(true) // paused (true) vs deactivated (false)
  createdAt    DateTime                     @default(now()) @map("created_at")
  triggeredAt  DateTime?                    @map("triggered_at")

  @@index([isActive])
  @@map("beacons")
}

model Match {
  id       String @id @default(cuid())
  agentAId String @map("agent_a_id")
  agentBId String @map("agent_b_id")
  agentA   Agent  @relation("AgentA", fields: [agentAId], references: [id])
  agentB   Agent  @relation("AgentB", fields: [agentBId], references: [id])

  // Which agent actually initiated the negotiation. (agentA/B is normalized by
  // id order for the uniqueness constraint and doesn't reflect initiation.)
  initiatorAgentId String? @map("initiator_agent_id")

  overlapSummary String @map("overlap_summary") // what agents decided in negotiation
  framingForA    String @map("framing_for_a") // how to present to owner A
  framingForB    String @map("framing_for_b") // how to present to owner B

  // V2 analytics fields — used for exact dashboard metrics.
  matchSimilarity   Float?               @map("match_similarity")
  discoverySource   MatchDiscoverySource @default(UNKNOWN) @map("discovery_source")
  sourceBeaconId    String?              @map("source_beacon_id")
  agentAAcceptedAt  DateTime?            @map("agent_a_accepted_at")
  agentBAcceptedAt  DateTime?            @map("agent_b_accepted_at")

  status       MatchStatus @default(NEGOTIATING)
  confirmedByA Boolean     @default(false) @map("confirmed_by_a")
  confirmedByB Boolean     @default(false) @map("confirmed_by_b")
  isPublic     Boolean     @default(true) @map("is_public")

  createdAt  DateTime  @default(now()) @map("created_at")
  proposedAt DateTime? @map("proposed_at")
  matchedAt  DateTime? @map("matched_at")

  chat            Chat?
  negotiationLogs NegotiationLog[]
  reactions       MatchReaction[]
  comments        MatchComment[]

  @@unique([agentAId, agentBId])
  @@map("matches")
}

enum MatchStatus {
  NEGOTIATING
  PROPOSED
  MATCHED
  DORMANT
  DECLINED
}

enum MatchDiscoverySource {
  UNKNOWN
  SEARCH
  BEACON
}

enum FreshnessState {
  ACTIVE
  AGING
  STALE
  INACTIVE
}

enum AgentType {
  OPENCLAW // OpenClaw and all derivatives (ZeroClaw, NemoClaw, SoulClaw, IronClaw)
}

enum IntegrationMethod {
  MCP // Connected via MCP
}

model Chat {
  id        String     @id @default(cuid())
  matchId   String     @unique @map("match_id")
  match     Match      @relation(fields: [matchId], references: [id])
  status    ChatStatus @default(OPEN)
  createdAt DateTime   @default(now()) @map("created_at")

  // Read cursors — tracks when each owner last viewed this chat
  lastReadByA DateTime? @map("last_read_by_a")
  lastReadByB DateTime? @map("last_read_by_b")

  // Email notification throttle — tracks when each owner was last emailed about new messages
  lastNotifiedA DateTime? @map("last_notified_a")
  lastNotifiedB DateTime? @map("last_notified_b")

  messages       Message[]
  reports        Report[]
  adviceSessions AdviceSession[]

  @@map("chats")
}

enum ChatStatus {
  OPEN
  ARCHIVED
  BLOCKED
}

enum AdviceSessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
  FAILED
  CANCELLED
}

enum MessageKind {
  HUMAN
  AGENT_INTRO
  MODEL_ADVICE_REQUEST
  MODEL_ADVICE_STATUS
  MODEL_ADVICE_AGENT
  MODEL_ADVICE_RESULT
}

model Message {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  chat      Chat     @relation(fields: [chatId], references: [id])
  fromOwner String   @map("from_owner") // owner id or "agent_a" / "agent_b" for opening messages
  kind      MessageKind @default(HUMAN)
  adviceSessionId String? @map("advice_session_id")
  adviceSession   AdviceSession? @relation(fields: [adviceSessionId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@index([adviceSessionId])
  @@map("messages")
}

model AdviceSession {
  id                 String              @id @default(cuid())
  chatId             String              @map("chat_id")
  chat               Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  requestedByOwnerId String              @map("requested_by_owner_id")
  responderOwnerId   String?             @map("responder_owner_id")
  promptKey          String?             @map("prompt_key")
  promptTitle        String              @map("prompt_title")
  promptText         String              @map("prompt_text")
  status             AdviceSessionStatus @default(PENDING)
  respondedAt        DateTime?           @map("responded_at")
  startedAt          DateTime?           @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  summary            String?             @map("summary")
  recommendation     String?             @map("recommendation")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  messages Message[]

  @@index([chatId, status])
  @@index([requestedByOwnerId, status])
  @@map("advice_sessions")
}

model NegotiationLog {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id])
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id])
  role      String // "initiator" | "responder"
  type      String // "reasoning" | "proposal" | "evaluation" | "agreement" | "decline"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("negotiation_logs")
}

model MatchReaction {
  id        String       @id @default(cuid())
  matchId   String       @map("match_id")
  match     Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String       @map("owner_id")
  owner     Owner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([matchId, ownerId])
  @@index([matchId])
  @@map("match_reactions")
}

model MatchComment {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ownerId   String   @map("owner_id")
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@map("match_comments")
}

enum ReactionType {
  LIKE
  DISLIKE
}

model ConsentLog {
  id          String    @id @default(cuid())
  ownerId     String    @map("owner_id")
  owner       Owner     @relation(fields: [ownerId], references: [id])
  purpose     String // "A" (networking) | "B" (research)
  consentedAt DateTime  @default(now()) @map("consented_at")
  withdrawnAt DateTime? @map("withdrawn_at")

  @@index([ownerId])
  @@map("consent_logs")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blocker   Owner    @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String   @map("blocked_id")
  blocked   Owner    @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Report {
  id         String   @id @default(cuid())
  chatId     String   @map("chat_id")
  chat       Chat     @relation(fields: [chatId], references: [id])
  reporterId String   @map("reporter_id")
  reporter   Owner    @relation(fields: [reporterId], references: [id])
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model DemoResponderLog {
  id           String   @id @default(cuid())
  demoAgentId  String   @map("demo_agent_id")
  event        String // NEGOTIATE_RESPOND | NEGOTIATE_INITIATE | CHAT_REPLY | MATCH_CONFIRM | PROPOSE
  targetId     String?  @map("target_id") // matchId | chatId | messageId
  targetType   String?  @map("target_type") // match | chat | message
  mcpTool      String?  @map("mcp_tool") // which MCP tool was called on the agent's behalf
  latencyMs    Int?     @map("latency_ms")
  tokensInput  Int?     @map("tokens_input")
  tokensOutput Int?     @map("tokens_output")
  costUsd      Float?   @map("cost_usd")
  success      Boolean
  errorCode    String?  @map("error_code")
  errorMessage String?  @map("error_message")
  llmPrompt    String?  @map("llm_prompt")
  llmResponse  String?  @map("llm_response")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([demoAgentId, createdAt])
  @@index([event, createdAt])
  @@index([success, createdAt])
  @@map("demo_responder_logs")
}

model DemoAgentQuota {
  id                    String   @id @default(cuid())
  demoAgentId           String   @map("demo_agent_id")
  day                   DateTime @db.Date
  negotiationsInitiated Int      @default(0) @map("negotiations_initiated")
  negotiationsResponded Int      @default(0) @map("negotiations_responded")
  chatMessagesSent      Int      @default(0) @map("chat_messages_sent")
  llmCalls              Int      @default(0) @map("llm_calls")
  tokensUsed            Int      @default(0) @map("tokens_used")
  costUsd               Float    @default(0) @map("cost_usd")
  paused                Boolean  @default(false)
  pauseReason           String?  @map("pause_reason")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([demoAgentId, day])
  @@index([day])
  @@map("demo_agent_quotas")
}

// Inbox events — primary delivery channel for agent-visible notifications.
// Written by Gennety on match/message/freshness events, read by the agent
// via the check_in MCP tool, acknowledged via ack_inbox after delivery to owner.
model InboxEvent {
  id          String    @id @default(cuid())
  ownerId     String    @map("owner_id")
  agentId     String    @map("agent_id") // internal Agent.id
  type        String // NEW_MESSAGE | MATCH_PROPOSED | MATCH_CONFIRMED | BEACON_TRIGGERED | FRESHNESS_WARNING
  referenceId String    @map("reference_id") // matchId | beaconId | agentId
  payload     Json // self-contained fields for the agent
  createdAt   DateTime  @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at") // first time check_in returned this event
  dismissedAt DateTime? @map("dismissed_at") // agent acknowledged delivery to owner

  @@index([agentId, dismissedAt])
  @@index([ownerId, type, referenceId])
  @@index([createdAt])
  @@map("inbox_events")
}

// Append-only analytics lifecycle ledger.
// Used for precise admin dashboard metrics without scanning business tables heuristically.
model AnalyticsEvent {
  id              String   @id @default(cuid())
  type            String
  ownerId         String?  @map("owner_id")
  agentId         String?  @map("agent_id")
  matchId         String?  @map("match_id")
  beaconId        String?  @map("beacon_id")
  chatId          String?  @map("chat_id")
  adviceSessionId String?  @map("advice_session_id")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([ownerId, createdAt])
  @@index([agentId, createdAt])
  @@index([matchId, createdAt])
  @@index([beaconId, createdAt])
  @@index([chatId, createdAt])
  @@index([adviceSessionId, createdAt])
  @@map("analytics_events")
}

// Precise compute ledger for production and demo cost tracking.
model ComputeUsage {
  id              String   @id @default(cuid())
  category        String
  provider        String
  model           String
  operation       String
  ownerId         String?  @map("owner_id")
  agentId         String?  @map("agent_id")
  matchId         String?  @map("match_id")
  beaconId        String?  @map("beacon_id")
  chatId          String?  @map("chat_id")
  adviceSessionId String?  @map("advice_session_id")
  tokensInput     Int      @default(0) @map("tokens_input")
  tokensOutput    Int      @default(0) @map("tokens_output")
  costUsd         Float    @default(0) @map("cost_usd")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([category, createdAt])
  @@index([operation, createdAt])
  @@index([ownerId, createdAt])
  @@index([agentId, createdAt])
  @@index([matchId, createdAt])
  @@index([beaconId, createdAt])
  @@index([chatId, createdAt])
  @@index([adviceSessionId, createdAt])
  @@map("compute_usage")
}
