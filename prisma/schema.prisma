model Report {
  id         String   @id @default(cuid())
  chatId     String   @map("chat_id")
  chat       Chat     @relation(fields: [chatId], references: [id])
  reporterId String   @map("reporter_id")
  reporter   Owner    @relation(fields: [reporterId], references: [id])
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model DemoResponderLog {
  id           String   @id @default(cuid())
  demoAgentId  String   @map("demo_agent_id")
  event        String // NEGOTIATE_RESPOND | NEGOTIATE_INITIATE | CHAT_REPLY | MATCH_CONFIRM | PROPOSE
  targetId     String?  @map("target_id") // matchId | chatId | messageId
  targetType   String?  @map("target_type") // match | chat | message
  mcpTool      String?  @map("mcp_tool") // which MCP tool was called on the agent's behalf
  latencyMs    Int?     @map("latency_ms")
  tokensInput  Int?     @map("tokens_input")
  tokensOutput Int?     @map("tokens_output")
  costUsd      Float?   @map("cost_usd")
  success      Boolean
  errorCode    String?  @map("error_code")
  errorMessage String?  @map("error_message")
  llmPrompt    String?  @map("llm_prompt")
  llmResponse  String?  @map("llm_response")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([demoAgentId, createdAt])
  @@index([event, createdAt])
  @@index([success, createdAt])
  @@map("demo_responder_logs")
}

model DemoAgentQuota {
  id                    String   @id @default(cuid())
  demoAgentId           String   @map("demo_agent_id")
  day                   DateTime @db.Date
  negotiationsInitiated Int      @default(0) @map("negotiations_initiated")
  negotiationsResponded Int      @default(0) @map("negotiations_responded")
  chatMessagesSent      Int      @default(0) @map("chat_messages_sent")
  llmCalls              Int      @default(0) @map("llm_calls")
  tokensUsed            Int      @default(0) @map("tokens_used")
  costUsd               Float    @default(0) @map("cost_usd")
  paused                Boolean  @default(false)
  pauseReason           String?  @map("pause_reason")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([demoAgentId, day])
  @@index([day])
  @@map("demo_agent_quotas")
}

// Inbox events — primary delivery channel for agent-visible notifications.
// Written by Gennety on match/message/freshness events, read by the agent
// via the check_in MCP tool, acknowledged via ack_inbox after delivery to owner.
model InboxEvent {
  id          String    @id @default(cuid())
  ownerId     String    @map("owner_id")
  agentId     String    @map("agent_id") // internal Agent.id
  type        String // NEW_MESSAGE | MATCH_PROPOSED | MATCH_CONFIRMED | BEACON_TRIGGERED | FRESHNESS_WARNING
  referenceId String    @map("reference_id") // matchId | beaconId | agentId
  payload     Json // self-contained fields for the agent
  createdAt   DateTime  @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at") // first time check_in returned this event
  dismissedAt DateTime? @map("dismissed_at") // agent acknowledged delivery to owner

  @@index([agentId, dismissedAt])
  @@index([ownerId, type, referenceId])
  @@index([createdAt])
  @@map("inbox_events")
}

// Append-only analytics lifecycle ledger.
// Used for precise admin dashboard metrics without scanning business tables heuristically.
model AnalyticsEvent {
  id                String   @id @default(cuid())
  type              String
  ownerId           String?  @map("owner_id")
  agentId           String?  @map("agent_id")
  matchId           String?  @map("match_id")
  beaconId          String?  @map("beacon_id")
  chatId            String?  @map("chat_id")
  adviceSessionId   String?  @map("advice_session_id")
  communityId       String?  @map("community_id")
  strategySessionId String?  @map("strategy_session_id")
  knowledgeSourceId String?  @map("knowledge_source_id")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([ownerId, createdAt])
  @@index([agentId, createdAt])
  @@index([matchId, createdAt])
  @@index([beaconId, createdAt])
  @@index([chatId, createdAt])
  @@index([adviceSessionId, createdAt])
  @@index([communityId, createdAt])
  @@index([strategySessionId, createdAt])
  @@index([knowledgeSourceId, createdAt])
  @@map("analytics_events")
}

// Precise compute ledger for production and demo cost tracking.
model ComputeUsage {
  id                String   @id @default(cuid())
  category          String
  provider          String
  model             String
  operation         String
  ownerId           String?  @map("owner_id")
  agentId           String?  @map("agent_id")
  matchId           String?  @map("match_id")
  beaconId          String?  @map("beacon_id")
  chatId            String?  @map("chat_id")
  adviceSessionId   String?  @map("advice_session_id")
  communityId       String?  @map("community_id")
  strategySessionId String?  @map("strategy_session_id")
  knowledgeSourceId String?  @map("knowledge_source_id")
  tokensInput       Int      @default(0) @map("tokens_input")
  tokensOutput      Int      @default(0) @map("tokens_output")
  costUsd           Float    @default(0) @map("cost_usd")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([category, createdAt])
  @@index([operation, createdAt])
  @@index([ownerId, createdAt])
  @@index([agentId, createdAt])
  @@index([matchId, createdAt])
  @@index([beaconId, createdAt])
  @@index([chatId, createdAt])
  @@index([adviceSessionId, createdAt])
  @@index([communityId, createdAt])
  @@index([strategySessionId, createdAt])
  @@index([knowledgeSourceId, createdAt])
  @@map("compute_usage")
}
