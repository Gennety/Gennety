# ══════════════════════════════════════════════════════════════════
# Gennety — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# === Database (PostgreSQL + pgvector) ===
# Local development (Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/gennety"
DIRECT_URL="postgresql://postgres:postgres@localhost:54322/gennety"
# Production (Supabase):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# === OpenAI — for generating text-embedding-ada-002 embeddings (required) ===
OPENAI_API_KEY="sk-..."

# === Anthropic — for AI-generated chat opening messages (optional) ===
ANTHROPIC_API_KEY="sk-ant-..."

# === Resend — email notifications (optional) ===
RESEND_API_KEY=""

# === Telegram — admin bot alerts (optional) ===
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# === NextAuth (required) ===
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Cookie domain for cross-subdomain session sharing (set to ".yourdomain.com" in production)
NEXTAUTH_COOKIE_DOMAIN=""

# === Subdomain split (optional — leave empty for single-domain local dev) ===
NEXT_PUBLIC_APP_URL=""
NEXT_PUBLIC_LANDING_URL=""

# === Google OAuth (optional) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Vercel Cron — secret for authenticating cron job requests (optional) ===
CRON_SECRET=""

# === Supabase — for cookie consent logging (required in production) ===
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# === Cookie Consent — salt for hashing visitor IPs (required in production) ===
# Generate: openssl rand -hex 16
CONSENT_IP_SALT=""
